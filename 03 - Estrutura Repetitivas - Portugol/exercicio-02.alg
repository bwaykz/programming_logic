algoritmo "Senha_fixa"

var

senha, x : inteiro

inicio
  senha <- 2002
  
  escreval("******************")
  escreval("* Programa Senha *")
  escreval("******************")
  
  escreval(" ")

  escreval("digite a senha: ")
  leia(x)

  enquanto (x <> senha) faca
    escreval("Senha invalida! tente Novamente: ")
    leia(x)
  fimenquanto
  
  escreval("Acesso Permitido")





fimalgoritmo
